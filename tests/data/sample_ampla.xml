<?xml version="1.0" encoding="utf-8"?>
<Ampla>

  <!--
    Synthetic test fixture for Ampla to B2MML conversion.
    Designed to match exactly what the original XSLT produces.

    XSLT class processing:
      /Ampla/ClassDefinitions/ClassDefinition/ClassDefinition
      i.e. second-level and deeper nodes only.
      Top-level ClassDefinition nodes are always containers (skipped in naming).

    Classes produced:
      Crusher            (parent: none)
      Crusher.JawCrusher (parent: Crusher)

    Equipment produced:
      AcmeMining         (Enterprise)
        NorthMine        (Site)
          CrusherPlant   (Area, class=Crusher.JawCrusher, override MaxThroughput=850)
          ConveyorLoop   (Area, class=Crusher.JawCrusher, no override)
          WasteStorage   (Area, no class)
        SouthMine        (Site)
          ProcessPlant   (Area, class=Crusher)
        Applications     (Other)
  -->

  <Item id="ent-1" name="AcmeMining" type="Citect.Ampla.Isa95.EnterpriseFolder">

    <Item id="site-1" name="NorthMine" type="Citect.Ampla.Isa95.SiteFolder">

      <Item id="area-1" name="CrusherPlant" type="Citect.Ampla.Isa95.AreaFolder">
        <ItemClassAssociation classDefinitionId="cls-grandchild"/>
        <Property name="Class.MaxThroughput">850</Property>
      </Item>

      <Item id="area-2" name="ConveyorLoop" type="Citect.Ampla.Isa95.AreaFolder">
        <ItemClassAssociation classDefinitionId="cls-grandchild"/>
      </Item>

      <Item id="area-3" name="WasteStorage" type="Citect.Ampla.Isa95.AreaFolder"/>

    </Item>

    <Item id="site-2" name="SouthMine" type="Citect.Ampla.Isa95.SiteFolder">

      <Item id="area-4" name="ProcessPlant" type="Citect.Ampla.Isa95.AreaFolder">
        <ItemClassAssociation classDefinitionId="cls-child"/>
      </Item>

    </Item>

    <Item id="apps-1" name="Applications" type="Citect.Ampla.General.Server.ApplicationsFolder"/>

  </Item>

  <ClassDefinitions>

    <!--
      Container node (skipped in naming).
      Real classes: Crusher, Crusher.JawCrusher
    -->
    <ClassDefinition id="cls-container" name="ProcessingUnit">

      <ClassDefinition id="cls-child" name="Crusher">
        <PropertyDefinition name="DriveType"    type="System.String">Electric</PropertyDefinition>
        <PropertyDefinition name="Manufacturer" type="System.String">Unknown</PropertyDefinition>

        <ClassDefinition id="cls-grandchild" name="JawCrusher">
          <PropertyDefinition name="MaxThroughput" type="System.Int32">750</PropertyDefinition>
        </ClassDefinition>

      </ClassDefinition>

    </ClassDefinition>

  </ClassDefinitions>

</Ampla>